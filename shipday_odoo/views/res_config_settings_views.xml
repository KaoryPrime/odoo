<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_shipday" model="ir.ui.view">
        <field name="name">res.config.settings.shipday.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app name="shipday_odoo" string="Shipday" groups="base.group_system">
                    <block title="Shipday — Dispatch livraison">
                        <setting string="Clé API Shipday"
                                 help="Disponible dans votre tableau de bord Shipday → Settings → API Key.">
                            <field name="shipday_api_key"
                                   password="True"
                                   placeholder="Votre clé API Shipday…"/>
                        </setting>
                        <setting string="Nom du restaurant">
                            <field name="shipday_restaurant_name"
                                   placeholder="Nom du restaurant"/>
                        </setting>
                        <setting string="Adresse du restaurant">
                            <field name="shipday_restaurant_address"
                                   placeholder="Adresse complète"/>
                        </setting>
                        <setting string="Téléphone du restaurant">
                            <field name="shipday_restaurant_phone"
                                   placeholder="Téléphone"/>
                        </setting>
                        <setting string="Délai de livraison par défaut (minutes)"
                                 help="Nombre de minutes après l'heure de pickup pour estimer la livraison.">
                            <field name="shipday_default_delivery_delay"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
