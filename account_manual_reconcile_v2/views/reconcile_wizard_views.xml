<odoo>
    <record id="view_manual_reconcile_wizard_form" model="ir.ui.view">
        <field name="name">manual.reconcile.wizard.form</field>
        <field name="model">manual.reconcile.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="move_ids" widget="many2many_tags"/>
                    <field name="partner_id" readonly="1" force_save="1"/>
                    <field name="payment_ids" widget="many2many_tags"
                           domain="[('partner_id', '=', partner_id)]"/>
                </group>
                <footer>
                    <button string="Créer un Paiement" type="object" name="action_create_payment" class="btn-secondary"/>
                    <button string="Lettrer" type="object" name="action_manual_reconcile" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_manual_reconcile_wizard" model="ir.actions.act_window">
        <field name="name">Assistant Lettrage Manuel</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">manual.reconcile.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_manual_reconcile_wizard"
              name="Effectuer un Lettrage"
              parent="menu_manual_reconcile_root"
              sequence="10"
              action="action_manual_reconcile_wizard"/>
</odoo>