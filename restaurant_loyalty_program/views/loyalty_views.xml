<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_loyalty_card_form" model="ir.ui.view">
        <field name="name">restaurant.loyalty.card.form</field>
        <field name="model">restaurant.loyalty.card</field>
        <field name="arch" type="xml">
            <form string="Carte de fidélité">
                <header>
                    <button name="action_view_history"
                            string="Historique"
                            type="object"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_history"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-history">
                            <field name="total_points_earned"
                                   string="Points gagnés"
                                   widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="True"/></h1>
                    </div>
                    <group>
                        <group string="Informations">
                            <field name="partner_id"/>
                            <field name="card_number"/>
                            <field name="active" invisible="True"/>
                        </group>
                        <group string="Points">
                            <field name="points_balance"/>
                            <field name="total_points_earned"/>
                            <field name="total_points_spent"/>
                            <field name="tier" widget="badge"
                                   decoration-success="tier == 'gold' or tier == 'platinum'"
                                   decoration-info="tier == 'silver'"
                                   decoration-warning="tier == 'bronze'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Historique" name="history">
                            <field name="history_ids" readonly="True">
                                <list>
                                    <field name="date"/>
                                    <field name="operation" widget="badge"
                                           decoration-success="operation == 'earn'"
                                           decoration-danger="operation == 'redeem'"/>
                                    <field name="points"/>
                                    <field name="description"/>
                                    <field name="sale_order_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_loyalty_card_list" model="ir.ui.view">
        <field name="name">restaurant.loyalty.card.list</field>
        <field name="model">restaurant.loyalty.card</field>
        <field name="arch" type="xml">
            <list string="Cartes de fidélité"
                  decoration-success="tier == 'gold' or tier == 'platinum'"
                  decoration-info="tier == 'silver'">
                <field name="card_number"/>
                <field name="partner_id"/>
                <field name="points_balance"/>
                <field name="total_points_earned" optional="show"/>
                <field name="total_points_spent" optional="hide"/>
                <field name="tier" widget="badge"
                       decoration-success="tier == 'gold' or tier == 'platinum'"
                       decoration-info="tier == 'silver'"
                       decoration-warning="tier == 'bronze'"/>
            </list>
        </field>
    </record>

    <record id="view_loyalty_card_search" model="ir.ui.view">
        <field name="name">restaurant.loyalty.card.search</field>
        <field name="model">restaurant.loyalty.card</field>
        <field name="arch" type="xml">
            <search string="Recherche carte fidélité">
                <field name="partner_id"/>
                <field name="card_number"/>
                <separator/>
                <filter string="Bronze" name="bronze"
                        domain="[('tier', '=', 'bronze')]"/>
                <filter string="Silver" name="silver"
                        domain="[('tier', '=', 'silver')]"/>
                <filter string="Gold" name="gold"
                        domain="[('tier', '=', 'gold')]"/>
                <filter string="Platinum" name="platinum"
                        domain="[('tier', '=', 'platinum')]"/>
                <separator/>
                <group expand="0" string="Regrouper par">
                    <filter string="Client" name="group_partner"
                            context="{'group_by': 'partner_id'}"/>
                    <filter string="Niveau" name="group_tier"
                            context="{'group_by': 'tier'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_loyalty_card" model="ir.actions.act_window">
        <field name="name">Cartes fidélité</field>
        <field name="res_model">restaurant.loyalty.card</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune carte de fidélité
            </p>
            <p>Créez une carte pour commencer le programme de fidélité.</p>
        </field>
    </record>

    <record id="view_loyalty_history_form" model="ir.ui.view">
        <field name="name">restaurant.loyalty.points.history.form</field>
        <field name="model">restaurant.loyalty.points.history</field>
        <field name="arch" type="xml">
            <form string="Historique des points">
                <sheet>
                    <group>
                        <group string="Informations">
                            <field name="card_id"/>
                            <field name="partner_id"/>
                            <field name="date"/>
                        </group>
                        <group string="Détails">
                            <field name="operation" widget="badge"
                                   decoration-success="operation == 'earn'"
                                   decoration-danger="operation == 'redeem'"/>
                            <field name="points"/>
                            <field name="description"/>
                            <field name="sale_order_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_loyalty_history_list" model="ir.ui.view">
        <field name="name">restaurant.loyalty.points.history.list</field>
        <field name="model">restaurant.loyalty.points.history</field>
        <field name="arch" type="xml">
            <list string="Historique des points"
                  decoration-success="operation == 'earn'"
                  decoration-danger="operation == 'redeem'">
                <field name="date"/>
                <field name="card_id"/>
                <field name="partner_id"/>
                <field name="operation" widget="badge"
                       decoration-success="operation == 'earn'"
                       decoration-danger="operation == 'redeem'"/>
                <field name="points"/>
                <field name="description"/>
                <field name="sale_order_id" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_loyalty_history_search" model="ir.ui.view">
        <field name="name">restaurant.loyalty.points.history.search</field>
        <field name="model">restaurant.loyalty.points.history</field>
        <field name="arch" type="xml">
            <search string="Recherche historique">
                <field name="card_id"/>
                <field name="partner_id"/>
                <separator/>
                <filter string="Gains" name="earn"
                        domain="[('operation', '=', 'earn')]"/>
                <filter string="Utilisations" name="redeem"
                        domain="[('operation', '=', 'redeem')]"/>
                <separator/>
                <group expand="0" string="Regrouper par">
                    <filter string="Carte" name="group_card"
                            context="{'group_by': 'card_id'}"/>
                    <filter string="Client" name="group_partner"
                            context="{'group_by': 'partner_id'}"/>
                    <filter string="Opération" name="group_operation"
                            context="{'group_by': 'operation'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_loyalty_history" model="ir.actions.act_window">
        <field name="name">Historique des points</field>
        <field name="res_model">restaurant.loyalty.points.history</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucun historique de points
            </p>
            <p>L'historique sera alimenté automatiquement.</p>
        </field>
    </record>

</odoo>
