<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_alert_rule_form" model="ir.ui.view">
        <field name="name">restaurant.stock.alert.rule.form</field>
        <field name="model">restaurant.stock.alert.rule</field>
        <field name="arch" type="xml">
            <form string="Règle d'alerte">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_alerts"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-bell">
                            <field name="alert_count"
                                   string="Alertes"
                                   widget="statinfo"/>
                        </button>
                    </div>
                    <widget name="web_ribbon"
                            title="Sous le seuil"
                            bg_color="text-bg-danger"
                            invisible="not is_below_threshold"/>
                    <div class="oe_title">
                        <h1><field name="name" readonly="True"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="category_id" readonly="True"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="min_quantity"/>
                            <field name="reorder_quantity"/>
                            <field name="current_stock" readonly="True"/>
                            <field name="is_below_threshold" readonly="True"/>
                            <field name="last_check_date" readonly="True"/>
                        </group>
                    </group>
                    <group>
                        <button name="action_check_stock"
                                string="Vérifier le stock"
                                type="object"
                                class="btn-primary"/>
                    </group>
                    <notebook>
                        <page string="Alertes" name="alerts">
                            <field name="alert_line_ids" readonly="True">
                                <list>
                                    <field name="alert_date"/>
                                    <field name="current_quantity"/>
                                    <field name="min_quantity"/>
                                    <field name="suggested_order"/>
                                    <field name="state" widget="badge"
                                           decoration-danger="state == 'new'"
                                           decoration-warning="state == 'acknowledged'"
                                           decoration-info="state == 'ordered'"
                                           decoration-success="state == 'resolved'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_stock_alert_rule_list" model="ir.ui.view">
        <field name="name">restaurant.stock.alert.rule.list</field>
        <field name="model">restaurant.stock.alert.rule</field>
        <field name="arch" type="xml">
            <list string="Règles d'alerte"
                  decoration-danger="is_below_threshold == True"
                  decoration-success="is_below_threshold == False">
                <field name="product_id"/>
                <field name="category_id" optional="show"/>
                <field name="min_quantity"/>
                <field name="reorder_quantity"/>
                <field name="current_stock"/>
                <field name="is_below_threshold" widget="boolean"
                       string="Sous le seuil"/>
                <field name="alert_count"/>
                <field name="last_check_date" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_stock_alert_rule_search" model="ir.ui.view">
        <field name="name">restaurant.stock.alert.rule.search</field>
        <field name="model">restaurant.stock.alert.rule</field>
        <field name="arch" type="xml">
            <search string="Rechercher">
                <field name="product_id"/>
                <field name="category_id"/>
                <separator/>
                <filter string="Sous le seuil" name="below_threshold"
                        domain="[('is_below_threshold', '=', True)]"/>
                <filter string="Actif" name="active"
                        domain="[('active', '=', True)]"/>
                <separator/>
                <group expand="0" string="Grouper par">
                    <filter string="Catégorie" name="group_category"
                            context="{'group_by': 'category_id'}"/>
                    <filter string="Produit" name="group_product"
                            context="{'group_by': 'product_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_stock_alert_rule" model="ir.actions.act_window">
        <field name="name">Règles d'alerte</field>
        <field name="res_model">restaurant.stock.alert.rule</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune règle d'alerte configurée
            </p>
            <p>
                Créez des règles pour surveiller automatiquement les niveaux de stock
                et recevoir des alertes de réapprovisionnement.
            </p>
        </field>
    </record>

    <record id="view_stock_alert_line_form" model="ir.ui.view">
        <field name="name">restaurant.stock.alert.line.form</field>
        <field name="model">restaurant.stock.alert.line</field>
        <field name="arch" type="xml">
            <form string="Alerte de stock">
                <header>
                    <button name="action_acknowledge"
                            string="Acquitter"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'new'"/>
                    <button name="action_mark_ordered"
                            string="Marquer commandé"
                            type="object"
                            class="btn-primary"
                            invisible="state not in ['new', 'acknowledged']"/>
                    <button name="action_resolve"
                            string="Résoudre"
                            type="object"
                            invisible="state == 'resolved'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,acknowledged,ordered,resolved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="True"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="rule_id" readonly="True"/>
                            <field name="product_id" readonly="True"/>
                            <field name="alert_date" readonly="True"/>
                        </group>
                        <group>
                            <field name="current_quantity" readonly="True"/>
                            <field name="min_quantity" readonly="True"/>
                            <field name="suggested_order" readonly="state in ['ordered', 'resolved']"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_stock_alert_line_list" model="ir.ui.view">
        <field name="name">restaurant.stock.alert.line.list</field>
        <field name="model">restaurant.stock.alert.line</field>
        <field name="arch" type="xml">
            <list string="Alertes de stock"
                  decoration-danger="state == 'new'"
                  decoration-warning="state == 'acknowledged'"
                  decoration-info="state == 'ordered'"
                  decoration-success="state == 'resolved'">
                <field name="alert_date"/>
                <field name="product_id"/>
                <field name="current_quantity"/>
                <field name="min_quantity"/>
                <field name="suggested_order"/>
                <field name="state" widget="badge"
                       decoration-danger="state == 'new'"
                       decoration-warning="state == 'acknowledged'"
                       decoration-info="state == 'ordered'"
                       decoration-success="state == 'resolved'"/>
                <field name="color" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_stock_alert_line_search" model="ir.ui.view">
        <field name="name">restaurant.stock.alert.line.search</field>
        <field name="model">restaurant.stock.alert.line</field>
        <field name="arch" type="xml">
            <search string="Rechercher">
                <field name="product_id"/>
                <field name="rule_id"/>
                <separator/>
                <filter string="Nouveau" name="new"
                        domain="[('state', '=', 'new')]"/>
                <filter string="Acquitté" name="acknowledged"
                        domain="[('state', '=', 'acknowledged')]"/>
                <filter string="Commandé" name="ordered"
                        domain="[('state', '=', 'ordered')]"/>
                <filter string="Résolu" name="resolved"
                        domain="[('state', '=', 'resolved')]"/>
                <separator/>
                <group expand="0" string="Grouper par">
                    <filter string="Produit" name="group_product"
                            context="{'group_by': 'product_id'}"/>
                    <filter string="Statut" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Date" name="group_date"
                            context="{'group_by': 'alert_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_stock_alert_line_pivot" model="ir.ui.view">
        <field name="name">restaurant.stock.alert.line.pivot</field>
        <field name="model">restaurant.stock.alert.line</field>
        <field name="arch" type="xml">
            <pivot string="Analyse des alertes">
                <field name="product_id" type="row"/>
                <field name="alert_date" interval="month" type="col"/>
                <field name="id" type="measure" string="Nombre d'alertes"/>
            </pivot>
        </field>
    </record>

    <record id="action_stock_alert_line" model="ir.actions.act_window">
        <field name="name">Alertes de stock</field>
        <field name="res_model">restaurant.stock.alert.line</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_new': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune alerte de stock
            </p>
            <p>
                Les alertes seront générées automatiquement lorsque le stock
                d'un produit passe sous le seuil minimum défini.
            </p>
        </field>
    </record>

    <record id="action_stock_alert_line_analytics" model="ir.actions.act_window">
        <field name="name">Analytique Alertes</field>
        <field name="res_model">restaurant.stock.alert.line</field>
        <field name="view_mode">pivot,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune donnée analytique disponible
            </p>
            <p>
                Les données apparaîtront dès que des alertes seront générées.
            </p>
        </field>
    </record>

</odoo>
