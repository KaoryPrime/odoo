<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_shift_form" model="ir.ui.view">
        <field name="name">hr.shift.form</field>
        <field name="model">hr.shift</field>
        <field name="arch" type="xml">
            <form string="Shift">
                <header>
                    <button name="action_confirm"
                            string="Confirmer"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_done"
                            string="Terminer"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_cancel"
                            string="Annuler"
                            type="object"
                            invisible="state not in ['draft', 'confirmed']"/>
                    <button name="action_reset_draft"
                            string="Remettre en brouillon"
                            type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <div class="alert alert-warning d-flex align-items-center gap-2"
                         invisible="not warning_message">
                        <i class="fa fa-exclamation-triangle"/>
                        <field name="warning_message" readonly="True" nolabel="1"/>
                    </div>

                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nom du shift…"/></h1>
                    </div>

                    <group>
                        <group string="Informations">
                            <field name="employee_id"/>
                            <field name="department_id" readonly="True"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Horaires">
                            <field name="start_time"/>
                            <field name="end_time"/>
                            <field name="duration" readonly="True" widget="float_time"/>
                            <field name="duration_display" readonly="True"/>
                        </group>
                    </group>

                    <group string="Notes">
                        <field name="note" nolabel="1"
                               placeholder="Informations complémentaires sur ce shift…"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_hr_shift_list" model="ir.ui.view">
        <field name="name">hr.shift.list</field>
        <field name="model">hr.shift</field>
        <field name="arch" type="xml">
            <list string="Shifts"
                  decoration-success="state == 'done'"
                  decoration-info="state == 'confirmed'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id" optional="show"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="duration_display" string="Durée"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-info="state == 'confirmed'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="color" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_hr_shift_calendar" model="ir.ui.view">
        <field name="name">hr.shift.calendar</field>
        <field name="model">hr.shift</field>
        <field name="arch" type="xml">
            <calendar string="Planning des shifts"
                      date_start="start_time"
                      date_stop="end_time"
                      color="employee_id"
                      mode="week"
                      event_limit="5">
                <field name="employee_id" avatar_field="image_128"/>
                <field name="duration_display"/>
                <field name="state"/>
                <field name="color"/>
            </calendar>
        </field>
    </record>

    <record id="view_hr_shift_search" model="ir.ui.view">
        <field name="name">hr.shift.search</field>
        <field name="model">hr.shift</field>
        <field name="arch" type="xml">
            <search string="Rechercher un shift">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <separator/>
                <filter string="Brouillons" name="draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmés" name="confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter string="Terminés" name="done"
                        domain="[('state', '=', 'done')]"/>
                <filter string="Annulés" name="cancelled"
                        domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Aujourd'hui" name="today"
                        domain="[('start_time', '&gt;=', datetime.datetime.now().replace(hour=0,minute=0,second=0).strftime('%Y-%m-%d %H:%M:%S')),
                                 ('start_time', '&lt;=', datetime.datetime.now().replace(hour=23,minute=59,second=59).strftime('%Y-%m-%d %H:%M:%S'))]"/>
                <filter string="Cette semaine" name="this_week"
                        domain="[('start_time', '&gt;=', (datetime.date.today() - datetime.timedelta(days=datetime.date.today().weekday())).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Grouper par">
                    <filter string="Employé" name="group_employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter string="Département" name="group_department"
                            context="{'group_by': 'department_id'}"/>
                    <filter string="Statut" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Date de début" name="group_start"
                            context="{'group_by': 'start_time:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_shift" model="ir.actions.act_window">
        <field name="name">Shifts</field>
        <field name="res_model">hr.shift</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="context">{'search_default_confirmed': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez votre premier shift
            </p>
            <p>
                Gérez les plannings de vos employés avec contrôle automatique
                des règles RH (pause, durée journalière, chevauchements).
            </p>
        </field>
    </record>

</odoo>
