<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_shift_config_form" model="ir.ui.view">
        <field name="name">hr.shift.config.form</field>
        <field name="model">hr.shift.config</field>
        <field name="arch" type="xml">
            <form string="Configuration des règles RH">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nom de la configuration…"/></h1>
                    </div>
                    <group>
                        <group string="Règles de pause et durée journalière">
                            <field name="enforce_min_break"/>
                            <field name="min_break_minutes"
                                   invisible="not enforce_min_break"/>
                            <field name="enforce_max_hours"/>
                            <field name="max_hours_per_day"
                                   invisible="not enforce_max_hours"/>
                        </group>
                        <group string="Durée des shifts">
                            <field name="min_shift_duration"/>
                            <field name="max_shift_duration"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hr_shift_config_list" model="ir.ui.view">
        <field name="name">hr.shift.config.list</field>
        <field name="model">hr.shift.config</field>
        <field name="arch" type="xml">
            <list string="Configurations RH">
                <field name="name"/>
                <field name="min_break_minutes"/>
                <field name="max_hours_per_day"/>
                <field name="min_shift_duration"/>
                <field name="max_shift_duration"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="action_hr_shift_config" model="ir.actions.act_window">
        <field name="name">Configuration des règles RH</field>
        <field name="res_model">hr.shift.config</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
