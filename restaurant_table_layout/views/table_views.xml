<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_zone_form" model="ir.ui.view">
        <field name="name">restaurant.zone.form</field>
        <field name="model">restaurant.zone</field>
        <field name="arch" type="xml">
            <form string="Zone">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nom de la zone"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="zone_type"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="capacity"/>
                            <field name="table_count"/>
                            <field name="available_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Tables" name="tables">
                            <field name="table_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="capacity"/>
                                    <field name="shape"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'free'"
                                           decoration-danger="state == 'occupied'"
                                           decoration-info="state == 'reserved'"
                                           decoration-muted="state == 'maintenance'"/>
                                    <field name="waiter_id"/>
                                    <field name="current_guests"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_zone_list" model="ir.ui.view">
        <field name="name">restaurant.zone.list</field>
        <field name="model">restaurant.zone</field>
        <field name="arch" type="xml">
            <list string="Zones">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="zone_type"/>
                <field name="table_count"/>
                <field name="available_count"/>
                <field name="capacity"/>
            </list>
        </field>
    </record>

    <record id="view_table_form" model="ir.ui.view">
        <field name="name">restaurant.table.layout.form</field>
        <field name="model">restaurant.table.layout</field>
        <field name="arch" type="xml">
            <form string="Table">
                <header>
                    <button name="action_set_free"
                            string="Libérer"
                            type="object"
                            class="btn-success"
                            invisible="state == 'free'"/>
                    <button name="action_set_occupied"
                            string="Occuper"
                            type="object"
                            class="btn-danger"
                            invisible="state == 'occupied'"/>
                    <button name="action_set_reserved"
                            string="Réserver"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'reserved'"/>
                    <button name="action_set_maintenance"
                            string="Maintenance"
                            type="object"
                            invisible="state == 'maintenance'"/>
                    <button name="action_open_order"
                            string="Voir la commande"
                            type="object"
                            class="btn-secondary"
                            invisible="not current_order_id"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="free,occupied,reserved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Numéro de table"/></h1>
                    </div>
                    <group>
                        <group string="Informations">
                            <field name="zone_id"/>
                            <field name="capacity"/>
                            <field name="shape"/>
                        </group>
                        <group string="Service">
                            <field name="waiter_id"/>
                            <field name="current_guests"/>
                            <field name="current_order_id"
                                   readonly="state == 'maintenance'"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" placeholder="Notes..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_table_list" model="ir.ui.view">
        <field name="name">restaurant.table.layout.list</field>
        <field name="model">restaurant.table.layout</field>
        <field name="arch" type="xml">
            <list string="Tables"
                  decoration-success="state == 'free'"
                  decoration-danger="state == 'occupied'"
                  decoration-info="state == 'reserved'"
                  decoration-muted="state == 'maintenance'">
                <field name="name"/>
                <field name="zone_id"/>
                <field name="capacity"/>
                <field name="shape"/>
                <field name="waiter_id" optional="show"/>
                <field name="current_guests" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'free'"
                       decoration-danger="state == 'occupied'"
                       decoration-info="state == 'reserved'"
                       decoration-muted="state == 'maintenance'"/>
                <field name="color" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_table_search" model="ir.ui.view">
        <field name="name">restaurant.table.layout.search</field>
        <field name="model">restaurant.table.layout</field>
        <field name="arch" type="xml">
            <search string="Rechercher">
                <field name="name"/>
                <field name="zone_id"/>
                <field name="waiter_id"/>
                <separator/>
                <filter string="Libres" name="free"
                        domain="[('state', '=', 'free')]"/>
                <filter string="Occupées" name="occupied"
                        domain="[('state', '=', 'occupied')]"/>
                <filter string="Réservées" name="reserved"
                        domain="[('state', '=', 'reserved')]"/>
                <filter string="Maintenance" name="maintenance"
                        domain="[('state', '=', 'maintenance')]"/>
                <separator/>
                <group expand="0" string="Grouper par">
                    <filter string="Zone" name="group_zone"
                            context="{'group_by': 'zone_id'}"/>
                    <filter string="Statut" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Forme" name="group_shape"
                            context="{'group_by': 'shape'}"/>
                    <filter string="Serveur" name="group_waiter"
                            context="{'group_by': 'waiter_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_table_kanban" model="ir.ui.view">
        <field name="name">restaurant.table.layout.kanban</field>
        <field name="model">restaurant.table.layout</field>
        <field name="arch" type="xml">
            <kanban highlight_color="color">
                <field name="color"/>
                <templates>
                    <t t-name="card">
                        <field name="name" class="fw-bold fs-5"/>
                        <field name="zone_id"/>
                        <div>
                            <span>Places : </span>
                            <field name="capacity"/>
                        </div>
                        <field name="state" widget="badge"
                               decoration-success="state == 'free'"
                               decoration-danger="state == 'occupied'"
                               decoration-info="state == 'reserved'"
                               decoration-muted="state == 'maintenance'"/>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_table_layout" model="ir.actions.act_window">
        <field name="name">Tables</field>
        <field name="res_model">restaurant.table.layout</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune table pour le moment
            </p>
            <p>
                Créez vos tables pour gérer le plan de salle du restaurant.
            </p>
        </field>
    </record>

    <record id="action_table_kanban" model="ir.actions.act_window">
        <field name="name">Vue Kanban</field>
        <field name="res_model">restaurant.table.layout</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune table pour le moment
            </p>
            <p>
                Créez vos tables pour visualiser l'occupation en temps réel.
            </p>
        </field>
    </record>

    <record id="action_zone" model="ir.actions.act_window">
        <field name="name">Zones</field>
        <field name="res_model">restaurant.zone</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune zone définie
            </p>
            <p>
                Créez des zones pour organiser les tables de votre restaurant.
            </p>
        </field>
    </record>

</odoo>
