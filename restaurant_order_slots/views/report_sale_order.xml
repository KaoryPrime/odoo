<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_saleorder_document_inherit_slots"
              inherit_id="sale.report_saleorder_document"
              name="Créneaux restaurant — PDF">

        <xpath expr="//div[@class='page']/div[@class='row mt32 mb32']" position="after">

            <t t-if="doc.order_type or doc.pickup_date or doc.delivery_slot">
                <div class="row mt16">
                    <div class="col-12">
                        <div class="o_bold border-bottom pb-1 mb-2">
                            Informations de retrait / livraison
                        </div>
                    </div>
                </div>
                <div class="row">
                    <t t-if="doc.order_type">
                        <div class="col-4">
                            <strong>Type :</strong>
                            <span t-field="doc.order_type"/>
                        </div>
                    </t>
                    <t t-if="doc.pickup_date">
                        <div class="col-4">
                            <strong>Jour :</strong>
                            <span t-field="doc.pickup_date"/>
                        </div>
                    </t>
                    <t t-if="doc.delivery_slot">
                        <div class="col-4">
                            <strong>Créneau :</strong>
                            <span t-field="doc.delivery_slot"/>
                        </div>
                    </t>
                </div>
            </t>

        </xpath>
    </template>

</odoo>
