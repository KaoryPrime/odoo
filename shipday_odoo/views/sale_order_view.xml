<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_order_form_shipday" model="ir.ui.view">
        <field name="name">sale.order.shipday.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Boutons dans le header -->
            <xpath expr="//header" position="inside">

                <!-- Bouton envoi initial -->
                <button name="action_send_to_shipday"
                        type="object"
                        string="📦 Envoyer à Shipday"
                        class="btn-primary"
                        invisible="shipday_sent"
                        confirm="Envoyer cette commande vers Shipday ?"/>

                <!-- Bouton renvoi si déjà envoyé -->
                <button name="action_reset_shipday"
                        type="object"
                        string="🔄 Renvoyer à Shipday"
                        invisible="not shipday_sent"/>

            </xpath>

            <!-- Bandeau statut Shipday -->
            <xpath expr="//div[@name='button_box']" position="before">

                <!-- Envoyé avec succès -->
                <div class="alert alert-success d-flex align-items-center gap-2 mb-0 rounded-0 border-0 border-bottom"
                     invisible="not shipday_sent">
                    <i class="fa fa-truck fa-lg"/>
                    <span>
                        <strong>Commande transmise à Shipday.</strong>
                        <span invisible="not shipday_order_id" class="ms-2 text-muted">
                            ID : <field name="shipday_order_id" readonly="True" nolabel="1"/>
                        </span>
                    </span>
                </div>

                <!-- Erreur dernière tentative -->
                <div class="alert alert-danger d-flex align-items-center gap-2 mb-0 rounded-0 border-0 border-bottom"
                     invisible="not shipday_last_error or shipday_sent">
                    <i class="fa fa-exclamation-circle fa-lg"/>
                    <span>
                        <strong>Erreur Shipday : </strong>
                        <field name="shipday_last_error" readonly="True" nolabel="1"/>
                    </span>
                </div>

            </xpath>

            <!-- Champs cachés pour les conditions invisible= -->
            <xpath expr="//field[@name='state']" position="after">
                <field name="shipday_sent" invisible="True"/>
                <field name="shipday_order_id" invisible="True"/>
                <field name="shipday_last_error" invisible="True"/>
            </xpath>

        </field>
    </record>

    <!-- Colonne optionnelle dans la liste des commandes -->
    <record id="view_order_list_shipday" model="ir.ui.view">
        <field name="name">sale.order.shipday.list</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="shipday_sent"
                       string="Shipday"
                       widget="boolean_toggle"
                       readonly="True"
                       optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
