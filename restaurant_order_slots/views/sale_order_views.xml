<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_list_inherit_slots" model="ir.ui.view">
        <field name="name">sale.order.list.slots</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_order']" position="after">
                <field name="order_type" optional="show"/>
                <field name="pickup_date" optional="show"/>
                <field name="delivery_slot" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="sale_order_form_inherit_slots" model="ir.ui.view">
        <field name="name">sale.order.form.slots</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_order']" position="after">
                <field name="order_type"/>
                <field name="pickup_date" invisible="not order_type"/>
                <field name="delivery_slot" invisible="not order_type"/>
                <field name="order_slot_summary" readonly="True"
                       invisible="not order_slot_summary"/>
            </xpath>
        </field>
    </record>

</odoo>
